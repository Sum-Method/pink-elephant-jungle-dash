rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'initials', 'score', 'elapsedMs', 'fruit', 'crates', 'lives', 'createdAt'])
        && data.keys().size() == 8
        && data.uid is string && data.uid.size() <= 128
        && data.uid == request.auth.uid
        && data.initials is string && data.initials.size() == 3
        && data.score is number && data.score >= 0
        && data.elapsedMs is number && data.elapsedMs >= 0
        && data.fruit is number && data.fruit >= 0
        && data.crates is number && data.crates >= 0
        && data.lives is number && data.lives >= 0
        && data.createdAt == request.time;
    }

    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(scoreId) && isValidScore(incoming());
      // Scores should not be updated or deleted, strictly insert-only and read
      allow update, delete: if false;
    }
  }
}
